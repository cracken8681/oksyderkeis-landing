---
import { MONEY_OS } from "../config";
const { mode, checkoutUrl, launchPrice, futurePrice, features } = MONEY_OS;
---
<section id="money-os" class="relative px-5 py-16 scroll-mt-16">
  <div class="spotlight" aria-hidden="true"></div>
  <div class="relative max-w-3xl mx-auto rounded-3xl border border-gold-600/50 bg-gradient-to-b from-navy-800 to-navy-900 p-7 sm:p-10 shadow-2xl shadow-black/40">
    <p class="text-gold-500 tracking-widest text-xs uppercase mb-3">Pro · Το πλήρες σύστημα</p>
    <h2 class="text-2xl sm:text-3xl">Oksyderkeis Money OS Pro</h2>
    <p class="mt-3 text-ink-300 leading-relaxed">
      Το πλήρες σύστημα για να βλέπεις καθαρά τα χρήματά σου κάθε μήνα — έσοδα, έξοδα,
      αποταμίευση, στόχους και οικονομική πειθαρχία. Δεν είναι επενδυτική συμβουλή· είναι
      ένα σύστημα οργάνωσης που στήνεις σε ένα απόγευμα.
    </p>

    <ul class="mt-7 grid sm:grid-cols-2 gap-3">
      {features.map(([icon, title, desc]) => (
        <li class="rounded-2xl border border-navy-700 bg-navy-800/50 p-4">
          <p class="flex items-center gap-2 font-semibold text-ink-100">
            <span aria-hidden="true">{icon}</span>{title}
          </p>
          <p class="mt-1 text-sm text-ink-300 leading-relaxed">{desc}</p>
        </li>
      ))}
    </ul>

    <div class="mt-8 rounded-2xl border border-navy-700 bg-navy-900/40 p-5">
      <p class="text-gold-500 tracking-widest text-xs uppercase mb-4">Πώς δουλεύει</p>
      <ol class="grid sm:grid-cols-3 gap-4">
        <li class="flex gap-3">
          <span class="font-display text-gold-400 text-lg shrink-0" aria-hidden="true">1</span>
          <span class="text-sm text-ink-300 leading-relaxed">Πάρε το σύστημα — Sheets, prompts & workbook.</span>
        </li>
        <li class="flex gap-3">
          <span class="font-display text-gold-400 text-lg shrink-0" aria-hidden="true">2</span>
          <span class="text-sm text-ink-300 leading-relaxed">Στήσ' το σε ένα απόγευμα με το 7ήμερο πλάνο.</span>
        </li>
        <li class="flex gap-3">
          <span class="font-display text-gold-400 text-lg shrink-0" aria-hidden="true">3</span>
          <span class="text-sm text-ink-300 leading-relaxed">Δες καθαρά πού πάνε τα χρήματά σου κάθε μήνα.</span>
        </li>
      </ol>
    </div>

    <div class="mt-8 flex flex-col sm:flex-row sm:items-center gap-5 sm:gap-7">
      <div>
        <p class="font-display text-3xl text-gold-400">
          {launchPrice}
          <span class="text-base text-ink-500 line-through ml-2">{futurePrice}</span>
        </p>
        <p class="text-sm text-ink-500 mt-1">Τιμή launch · μετά {futurePrice}</p>
      </div>

      {mode === "live" ? (
        <a href={checkoutUrl} target="_blank" rel="noopener" data-cta="money-os-buy"
           class="inline-flex items-center justify-center rounded-full bg-gold-500 hover:bg-gold-400 transition-colors px-7 py-3.5 font-semibold text-navy-950">
          Θέλω το Money OS Pro
        </a>
      ) : (
        <div>
          <a href="#email" data-cta="money-os-waitlist"
             class="inline-flex items-center justify-center rounded-full bg-gold-500 hover:bg-gold-400 transition-colors px-7 py-3.5 font-semibold text-navy-950">
            Μπες στη waitlist — early access
          </a>
          <p class="mt-2 text-xs text-ink-500">Έρχεται σύντομα · οι εγγεγραμμένοι παίρνουν την τιμή launch.</p>
        </div>
      )}
    </div>
  </div>
</section>
