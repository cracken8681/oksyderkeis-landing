---
const points = [
  "Θέλεις να αρχίσεις να καταλαβαίνεις τις επενδύσεις, αλλά μπερδεύεσαι από τις πολλές πληροφορίες.",
  "Βαρέθηκες το hype και τις «σίγουρες ευκαιρίες».",
  "Θέλεις πειθαρχία και σύστημα — όχι εύκολο χρήμα.",
  "Ψάχνεις οικονομικές έννοιες εξηγημένες σε απλά ελληνικά.",
];
---
<section class="section-shell">
  <div class="max-w-4xl mx-auto">
    <p class="eyebrow justify-center w-full">Για ποιον είναι</p>
    <h2 class="mt-4 text-center section-title">Αν θες καθαρή σκέψη, όχι θόρυβο.</h2>
    <ul class="mt-10 grid gap-3 sm:grid-cols-2">
      {points.map((p, i) => (
        <li class="surface-card flex gap-4 p-5 sm:p-6">
          <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-gold-500/20 bg-gold-500/10 font-display text-gold-400">{String(i + 1).padStart(2, "0")}</span>
          <span class="text-ink-300 leading-relaxed">{p}</span>
        </li>
      ))}
    </ul>
  </div>
</section>
