---
const checkoutUrl = "https://ai-follow-up-scripts.mentorly.gr/p/ai-follow-up-scripts-mq9v3h5v";

const steps = [
  ["1", "Πάρε τα scripts", "Έτοιμα follow-up scripts για κάθε σενάριο — email, DM, τηλεφωνικές αντιρρήσεις."],
  ["2", "Εφάρμοσέ τα αμέσως", "Αντέγραψε, προσάρμοσε, στείλε — σε λιγότερο από 5 λεπτά ανά lead."],
  ["3", "Κλείσε περισσότερες πωλήσεις", "Κάθε χαμένη προσφορά έχει ένα σωστό follow-up — ακόμα και αν άφησε αναπάντητο."],
];

const features = [
  ["📩", "Scripts για email & DM", "Έτοιμα μηνύματα για κάθε στάδιο του κύκλου πωλήσεων."],
  ["📞", "Χειρισμός αντιρρήσεων", "Απαντήσεις σε «θα το σκεφτώ», «είναι ακριβό», «δεν είμαι έτοιμος»."],
  ["🔁", "Αλληλουχίες follow-up", "Πότε να ξαναστείλεις και τι να πεις — χωρίς να πιέζεις."],
  ["⚡", "Άμεση εφαρμογή", "Δεν χρειάζεται θεωρία — άνοιξε, αντέγραψε, στείλε."],
];
---

<section id="ai-follow-up" class="section-shell scroll-mt-16">
  <div class="spotlight" aria-hidden="true"></div>
  <div class="relative mx-auto max-w-6xl overflow-hidden rounded-[2rem] border border-gold-600/45 bg-gradient-to-b from-navy-800 to-navy-900 shadow-[0_30px_120px_rgba(0,0,0,0.42)]">

    <!-- Badge strip -->
    <div class="flex items-center gap-3 border-b border-navy-700/60 px-8 py-3 bg-gold-500/6">
      <span class="inline-flex items-center gap-1.5 rounded-full border border-gold-500/30 bg-gold-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-gold-300">
        Mentorly · €49
      </span>
      <span class="inline-flex items-center gap-1.5 rounded-full border border-red-500/30 bg-red-500/10 px-3 py-1 text-xs font-semibold text-red-400">
        -50% · από €97
      </span>
      <span class="text-xs text-ink-400">Μια φορά · Άμεση πρόσβαση</span>
    </div>

    <div class="grid gap-0 lg:grid-cols-[0.96fr_1.04fr]">
      <!-- Left: copy -->
      <div class="p-7 sm:p-10">
        <p class="eyebrow">Sales · Κλείσε την Πώληση</p>
        <h2 class="mt-4 section-title text-[clamp(1.8rem,4vw,2.8rem)] leading-tight">
          AI Follow-Up Scripts
        </h2>
        <p class="mt-2 text-gold-400 font-semibold text-lg">
          Μετέτρεψε τις Χαμένες Προσφορές σε Κερδοφόρες Πωλήσεις
        </p>
        <p class="mt-4 section-copy">
          Έτοιμα follow-up scripts με AI για κάθε σενάριο πωλήσεων. Αντί να χάνεις ευκαιρίες που «ξέχασες» να ακολουθήσεις, έχεις πάντα το σωστό μήνυμα — τη σωστή στιγμή.
        </p>

        <div class="mt-7 rounded-[1.4rem] border border-navy-700 bg-navy-950/35 p-5">
          <p class="text-xs uppercase tracking-[0.24em] text-gold-300">Πώς δουλεύει</p>
          <ol class="mt-4 grid gap-4 sm:grid-cols-3">
            {steps.map(([num, title, desc]) => (
              <li class="flex gap-3">
                <span class="font-display text-gold-400 text-lg shrink-0" aria-hidden="true">{num}</span>
                <div>
                  <p class="text-sm font-semibold text-ink-100">{title}</p>
                  <p class="text-xs text-ink-400 mt-0.5 leading-relaxed">{desc}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-4">
          <div>
            <div class="flex items-baseline gap-2">
              <p class="font-display text-3xl text-gold-400">47€</p>
              <p class="text-base text-ink-500 line-through">97€</p>
            </div>
            <p class="text-sm text-ink-500 mt-1">Τιμή launch · εφάπαξ · χωρίς συνδρομή</p>
          </div>
          <a
            href={checkoutUrl}
            target="_blank"
            rel="noopener"
            data-cta="ai-follow-up-buy"
            class="inline-flex items-center justify-center rounded-full bg-gold-500 px-7 py-3.5 font-semibold text-navy-950 transition-transform transition-colors hover:bg-gold-400 hover:-translate-y-0.5"
          >
            Θέλω τα Follow-Up Scripts
          </a>
        </div>
      </div>

      <!-- Right: features -->
      <div class="border-t border-navy-800/80 bg-navy-950/35 p-6 sm:p-8 lg:border-t-0 lg:border-l">
        <div class="grid gap-3 sm:grid-cols-2">
          {features.map(([icon, title, desc]) => (
            <div class="surface-card p-4">
              <p class="flex items-center gap-2 font-semibold text-ink-100">
                <span aria-hidden="true">{icon}</span>{title}
              </p>
              <p class="mt-1 text-sm text-ink-300 leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>

        <div class="mt-5 rounded-[1.4rem] border border-gold-500/20 bg-gold-500/8 p-4">
          <p class="text-xs uppercase tracking-[0.24em] text-gold-300">Τι κερδίζεις</p>
          <p class="mt-2 text-sm text-ink-100 leading-relaxed">
            Κάθε lead που δεν απαντά τώρα δεν είναι χαμένος. Με το σωστό follow-up, κλείνεις πωλήσεις που οι άλλοι αφήνουν να φύγουν.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
