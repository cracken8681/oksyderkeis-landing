---
import { YOUTUBE } from "../config";

// Build-time fetch του τελευταίου βίντεο μέσω YouTube RSS.
// Ανανεώνεται σε κάθε build/deploy (βλ. README: Vercel deploy hook / cron για auto-update).
// Fallback: latest known video (updated on each deploy via vidIQ)
const FALLBACK_VIDEO = { id: "jvey-R18Z1A", title: "Γιατί αποτυγχάνεις; Το κενό ανάμεσα σε σένα και την οικονομική ελευθερία" };

let video: { id: string; title: string } | null = null;

if (YOUTUBE.channelId && !YOUTUBE.channelId.startsWith("TODO")) {
  try {
    const res = await fetch(
      `https://www.youtube.com/feeds/videos.xml?channel_id=${YOUTUBE.channelId}`
    );
    if (res.ok) {
      const xml = await res.text();
      const idMatch = xml.match(/<yt:videoId>(.*?)<\/yt:videoId>/);
      const titleMatch = xml.match(/<entry>[\s\S]*?<title>(.*?)<\/title>/);
      if (idMatch) {
        video = {
          id: idMatch[1],
          title: titleMatch ? titleMatch[1] : "Τελευταίο βίντεο",
        };
      }
    }
  } catch (e) {
    console.warn("YouTube RSS fetch failed:", e);
  }
}

// Always show something — use fallback if RSS failed
if (!video) video = FALLBACK_VIDEO;
---
<section class="px-5 py-14 max-w-3xl mx-auto">
  <h2 class="text-2xl sm:text-3xl text-center mb-8">Τελευταίο βίντεο</h2>

  {video ? (
    <div
      id="yt-facade"
      class="relative aspect-video rounded-2xl overflow-hidden border border-navy-700 cursor-pointer group"
      data-id={video.id}
      role="button"
      tabindex="0"
      aria-label={`Αναπαραγωγή: ${video.title}`}
    >
      <img
        src={`https://i.ytimg.com/vi/${video.id}/hqdefault.jpg`}
        alt={video.title}
        loading="lazy"
        width="480" height="360"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-navy-950/30 group-hover:bg-navy-950/10 transition-colors"></div>
      <div class="absolute inset-0 flex items-center justify-center">
        <span class="flex items-center justify-center w-16 h-16 rounded-full bg-gold-500 text-navy-950 text-2xl">▶</span>
      </div>
    </div>
    <p class="mt-3 text-center text-ink-300">{video.title}</p>
    <script is:inline>
      (function () {
        const el = document.getElementById("yt-facade");
        if (!el) return;
        function load() {
          const id = el.getAttribute("data-id");
          el.outerHTML =
            '<iframe class="w-full aspect-video rounded-2xl border border-navy-700" src="https://www.youtube-nocookie.com/embed/' +
            id +
            '?autoplay=1" title="YouTube" frameborder="0" allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture" allowfullscreen></iframe>';
        }
        el.addEventListener("click", load);
        el.addEventListener("keydown", function (e) {
          if (e.key === "Enter" || e.key === " ") { e.preventDefault(); load(); }
        });
      })();
    </script>
  ) : (
    <div class="rounded-2xl border border-navy-800 bg-navy-900/50 p-8 text-center">
      <p class="text-ink-300">
        Βάλε το <code class="text-gold-400">channelId</code> στο <code class="text-gold-400">src/config.ts</code>
        για αυτόματο embed του τελευταίου βίντεο.
      </p>
      <a href={YOUTUBE.channelUrl} target="_blank" rel="noopener"
         class="inline-flex mt-4 rounded-full border border-gold-600 px-6 py-3 hover:bg-gold-500 hover:text-navy-950 transition-colors">
        Δες το κανάλι στο YouTube
      </a>
    </div>
  )}
</section>
