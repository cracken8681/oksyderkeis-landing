// Flatten for today/global index
const FLAT = [];
WEEKS.forEach(function(w){ w.days.forEach(function(d){ FLAT.push(d); }); });

function todayIdx(){
  const n=new Date(); n.setHours(0,0,0,0);
  const s=new Date(START); s.setHours(0,0,0,0);
  return Math.max(0,Math.min(Math.floor((n-s)/864e5),FLAT.length-1));
}
function load(){ try{ return JSON.parse(localStorage.getItem('ai30v2')||'{}'); }catch(e){ return {}; } }
function save(d){ localStorage.setItem('ai30v2',JSON.stringify(d)); }

function toggleDay(globalIdx){
  const d=load(); d[globalIdx]=!d[globalIdx]; save(d); render();
}
function completeToday(){ const i=todayIdx(); const d=load(); if(!d[i]){ d[i]=true; save(d); render(); } }

function typeClass(tp){ return ({yt:'yt',course:'course',cert:'cert',read:'read'})[tp]||'read'; }
function typeLabel(tp){ return ({yt:'YT',course:'COURSE',cert:'CERT',read:'READ'})[tp]||(tp||'').toUpperCase(); }

function render(){
  const ti = todayIdx();
  const done = load();
  const total = FLAT.length;
  const completedCount = Object.values(done).filter(Boolean).length;
  const pct = Math.round((completedCount/total)*100);

  document.getElementById('s-done').textContent = completedCount;
  document.getElementById('s-day').textContent = Math.min(ti+1, total);
  document.getElementById('s-pct').textContent = pct+'%';
  document.getElementById('overall-bar').style.width = pct+'%';

  // Today strip
  const td = FLAT[ti];
  document.getElementById('td-title').textContent = 'Μέρα '+(ti+1)+': '+td.t;
  document.getElementById('td-desc').textContent = td.d;
  const tdb = document.getElementById('td-btn');
  if(done[ti]){ tdb.textContent='✓ Ολοκληρώθηκε!'; tdb.className='td-btn done'; }
  else { tdb.textContent='✓ Ολοκλήρωσα'; tdb.className='td-btn'; }

  // Weeks
  const root = document.getElementById('root');
  // Preserve open state
  const openWeeks = {};
  root.querySelectorAll('.week-block').forEach(function(el,i){ openWeeks[i]=el.classList.contains('open'); });
  const openDays = {};
  root.querySelectorAll('.day-row').forEach(function(el){ if(el.dataset.gi!==undefined) openDays[el.dataset.gi]=el.classList.contains('open'); });

  root.innerHTML = '';
  let globalIdx = 0;

  WEEKS.forEach(function(w, wi){
    const weekDone = w.days.filter(function(d,di){ return !!done[globalIdx+di]; }).length;
    const weekTotal = w.days.length;
    const weekPct = Math.round((weekDone/weekTotal)*100);

    const isOpen = openWeeks[wi] !== undefined ? openWeeks[wi] : (w.days.some(function(d,di){ return (globalIdx+di)===ti; }));

    const block = document.createElement('div');
    block.className = 'week-block' + (isOpen?' open':'');

    block.innerHTML = '<div class="week-head" onclick="toggleWeek(this)">'
      +'<div class="wh-left"><span class="wh-title">'+w.wt+'</span><span class="wh-sub">'+w.ws+'</span></div>'
      +'<div class="wh-right">'
      +'<div class="week-progress-wrap"><div class="week-progress-fill" style="width:'+weekPct+'%"></div></div>'
      +'<span class="wh-pct">'+weekDone+'/'+weekTotal+'</span>'
      +'<span class="wh-arrow">▼</span>'
      +'</div></div>'
      +'<div class="days-list"></div>';

    const daysList = block.querySelector('.days-list');

    w.days.forEach(function(d, di){
      const gi = globalIdx + di;
      const isToday = gi === ti;
      const isDone = !!done[gi];
      const isDayOpen = openDays[gi] !== undefined ? openDays[gi] : isToday;

      const row = document.createElement('div');
      row.className = 'day-row'+(isToday?' is-today':'')+(isDayOpen?' open':'');
      row.dataset.gi = gi;

      const checkHtml = '<div class="day-check'+(isDone?' done':'')+(isToday&&!isDone?' today':'')+'">'+(isDone?'✓':'')+'</div>';
      const resHtml = (d.r||[]).map(function(r){
        return '<a class="res-a" href="'+r.u+'" target="_blank">'
          +'<span class="rflag">'+r.f+'</span>'
          +'<span class="rtype '+typeClass(r.tp)+'">'+typeLabel(r.tp)+'</span>'
          +'<span class="rtitle">'+r.n+'</span>'
          +'<span class="rfree">FREE</span>'
          +'</a>';
      }).join('');

      const btnLabel = isDone ? '✓ Ολοκληρώθηκε!' : '✓ Ολοκλήρωσα το μάθημα';
      const btnClass = isDone ? 'complete-btn done' : 'complete-btn';

      row.innerHTML = '<div class="day-head" onclick="toggleDay_row(this)">'
        +checkHtml
        +'<span class="day-num">'+(isToday?'▶ ':'')+'Μέρα '+(gi+1)+'</span>'
        +'<span class="day-title-row">'+d.t+'</span>'
        +'<span class="day-arrow">▼</span>'
        +'</div>'
        +'<div class="day-body">'
        +'<p class="day-desc-text">'+d.d+'</p>'
        +'<div class="res-list">'+resHtml+'</div>'
        +'<button class="'+btnClass+'"'+(isDone?' disabled':'')+' onclick="toggleDay('+gi+')">'+btnLabel+'</button>'
        +'</div>';

      daysList.appendChild(row);
    });

    root.appendChild(block);
    globalIdx += w.days.length;
  });
}

function toggleWeek(headEl){
  headEl.closest('.week-block').classList.toggle('open');
}
function toggleDay_row(headEl){
  headEl.closest('.day-row').classList.toggle('open');
}

render();
</script>
