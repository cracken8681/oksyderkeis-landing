---
import Base from "../layouts/Base.astro";
---

<Base
  title="AI Expert 30-Day Plan — David"
  description="30-ήμερο πρόγραμμα εκπαίδευσης AI για τον David — resources σε Ρωσικά, Ελληνικά και Αγγλικά."
>
<main class="plan-page">

  <!-- Header -->
  <section class="plan-hero">
    <div class="container">
      <p class="eyebrow">AI Expert Plan · David × Silvy · Ξεκίνησε 25 Ιουνίου 2026</p>
      <h1>30-Ήμερο Πρόγραμμα AI</h1>
      <p class="subtitle">Από βάση έως expert — resources σε 🇷🇺 Ρωσικά · 🇬🇷 Ελληνικά · 🇬🇧 Αγγλικά</p>

      <div class="hero-stats" id="hero-stats">
        <div class="stat-box">
          <span class="stat-num" id="stat-done">0</span>
          <span class="stat-label">Ολοκληρωμένες</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-box">
          <span class="stat-num" id="stat-today">1</span>
          <span class="stat-label">Σημερινή μέρα</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-box">
          <span class="stat-num" id="stat-pct">0%</span>
          <span class="stat-label">Πρόοδος</span>
        </div>
      </div>

      <div class="progress-track">
        <div class="progress-fill" id="progress-fill"></div>
      </div>
    </div>
  </section>

  <!-- Today Banner -->
  <div class="container">
    <div class="today-card" id="today-card">
      <div class="today-left">
        <span class="today-badge">▶ ΣΗΜΕΡΑ</span>
        <h2 id="today-title">Φόρτωση...</h2>
        <p id="today-desc"></p>
      </div>
      <button class="complete-btn" id="today-btn" onclick="completeTodayFromBanner()">
        ✓ Ολοκλήρωσα το μάθημα
      </button>
    </div>
  </div>

  <!-- Certs Row -->
  <div class="container">
    <div class="certs-row">
      <span class="certs-label">🎓 Στόχοι πιστοποίησης:</span>
      <a href="https://grow.google/ai" target="_blank" class="cert-pill">Google AI Essentials (δωρεάν)</a>
      <a href="https://learn.microsoft.com/en-us/credentials/certifications/ai-business-professional/" target="_blank" class="cert-pill">Microsoft AI Business Professional (~€100)</a>
      <a href="https://cloud.google.com/blog/topics/training-certifications/new-google-cloud-certification-in-generative-ai" target="_blank" class="cert-pill">Google Cloud Gen AI Leader</a>
    </div>
  </div>

  <!-- Days -->
  <div class="container" id="days-root"></div>

</main>

<style>
  .plan-page { max-width: 100%; overflow-x: hidden; }
  .container { max-width: 940px; margin: 0 auto; padding: 0 1.5rem; }

  /* Hero */
  .plan-hero {
    padding: 5rem 0 3rem;
    text-align: center;
    border-bottom: 1px solid rgba(212,175,87,0.12);
    background: radial-gradient(ellipse at 50% 0%, rgba(212,175,87,0.06) 0%, transparent 70%);
  }
  .eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold-500);
    margin-bottom: 1rem;
  }
  .plan-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: var(--color-ink-100);
    margin-bottom: 0.75rem;
  }
  .subtitle { color: var(--color-ink-300); font-size: 1rem; margin-bottom: 2.5rem; }

  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(212,175,87,0.15);
    border-radius: 12px;
    display: inline-flex;
    margin-bottom: 1.5rem;
    overflow: hidden;
  }
  .stat-box { padding: 1rem 2rem; text-align: center; }
  .stat-divider { width: 1px; height: 40px; background: rgba(255,255,255,0.08); }
  .stat-num {
    display: block;
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-gold-500);
    line-height: 1;
    margin-bottom: 0.25rem;
  }
  .stat-label { font-size: 0.7rem; color: var(--color-ink-500); text-transform: uppercase; letter-spacing: 0.06em; }

  .progress-track {
    background: rgba(255,255,255,0.08);
    border-radius: 99px;
    height: 6px;
    max-width: 400px;
    margin: 0 auto;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    border-radius: 99px;
    background: linear-gradient(90deg, var(--color-gold-500), #f0cc7a);
    transition: width 0.5s ease;
    width: 0%;
  }

  /* Today Card */
  .today-card {
    margin: 2rem 0 1.25rem;
    background: linear-gradient(135deg, rgba(212,175,87,0.1), rgba(212,175,87,0.04));
    border: 1px solid rgba(212,175,87,0.35);
    border-radius: 14px;
    padding: 1.75rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .today-left { flex: 1; min-width: 200px; }
  .today-badge {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-gold-500);
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.5rem;
  }
  .today-card h2 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--color-ink-100);
    margin-bottom: 0.35rem;
  }
  .today-card p { font-size: 0.88rem; color: var(--color-ink-300); line-height: 1.5; }

  .complete-btn {
    background: var(--color-gold-500);
    color: var(--color-navy-950);
    font-weight: 700;
    font-size: 0.88rem;
    padding: 0.8rem 1.5rem;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s, transform 0.15s;
  }
  .complete-btn:hover { background: #f0cc7a; transform: translateY(-1px); }
  .complete-btn.done {
    background: #10b981;
    color: white;
    cursor: default;
    transform: none;
  }

  /* Certs Row */
  .certs-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
    padding: 0.9rem 1.25rem;
    background: rgba(212,175,87,0.03);
    border: 1px solid rgba(212,175,87,0.12);
    border-radius: 10px;
  }
  .certs-label { font-size: 0.78rem; color: var(--color-ink-300); white-space: nowrap; }
  .cert-pill {
    font-size: 0.75rem;
    color: var(--color-gold-500);
    border: 1px solid rgba(212,175,87,0.3);
    border-radius: 99px;
    padding: 0.3rem 0.85rem;
    text-decoration: none;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .cert-pill:hover { background: rgba(212,175,87,0.1); }

  /* Week block */
  .week-block { margin-bottom: 2.5rem; }
  .week-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(212,175,87,0.15);
  }
  .week-header h2 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-gold-500);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .week-header p { font-size: 0.82rem; color: var(--color-ink-400); }

  .days-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  /* Day card */
  .day-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px;
    padding: 1.25rem;
    transition: border-color 0.15s, background 0.15s;
    position: relative;
    overflow: hidden;
  }
  .day-card:hover { border-color: rgba(212,175,87,0.2); background: rgba(255,255,255,0.03); }
  .day-card.is-today {
    border-color: rgba(212,175,87,0.4);
    background: rgba(212,175,87,0.05);
  }
  .day-card.is-done {
    opacity: 0.6;
  }
  .day-card.is-done::after {
    content: '✓';
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    width: 22px;
    height: 22px;
    background: #10b981;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    color: white;
    font-weight: 700;
    line-height: 22px;
    text-align: center;
  }

  .day-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.6rem;
  }
  .day-num-label {
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--color-ink-500);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .is-today .day-num-label { color: var(--color-gold-500); }

  .day-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-ink-100);
    margin-bottom: 0.4rem;
    line-height: 1.35;
  }
  .day-desc {
    font-size: 0.78rem;
    color: var(--color-ink-400);
    line-height: 1.55;
    margin-bottom: 0.85rem;
  }

  .res-list { display: flex; flex-direction: column; gap: 0.3rem; margin-bottom: 1rem; }
  .res-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.55rem;
    border-radius: 6px;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.05);
    text-decoration: none;
    transition: all 0.12s;
  }
  .res-link:hover { background: rgba(212,175,87,0.07); border-color: rgba(212,175,87,0.2); }
  .res-flag { font-size: 0.85rem; flex-shrink: 0; }
  .res-type {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.12rem 0.38rem;
    border-radius: 3px;
    flex-shrink: 0;
  }
  .rt-yt { background: rgba(255,50,50,0.15); color: #ff7070; }
  .rt-course { background: rgba(60,130,246,0.15); color: #7ab4ff; }
  .rt-cert { background: rgba(212,175,87,0.15); color: var(--color-gold-500); }
  .rt-read { background: rgba(16,185,129,0.15); color: #4ade80; }
  .res-title { font-size: 0.75rem; color: var(--color-ink-400); line-height: 1.3; }
  .res-link:hover .res-title { color: var(--color-ink-100); }
  .res-free { margin-left: auto; font-size: 0.6rem; color: #4ade80; font-weight: 700; flex-shrink: 0; }

  .day-complete-btn {
    width: 100%;
    padding: 0.6rem;
    border-radius: 7px;
    border: 1px solid rgba(212,175,87,0.25);
    background: transparent;
    color: var(--color-gold-500);
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
  }
  .day-complete-btn:hover { background: rgba(212,175,87,0.08); border-color: rgba(212,175,87,0.5); }
  .day-complete-btn.done {
    background: rgba(16,185,129,0.1);
    border-color: rgba(16,185,129,0.3);
    color: #4ade80;
    cursor: default;
  }
</style>

