function today() {
  const now = new Date(); now.setHours(0,0,0,0);
  const s = new Date(START); s.setHours(0,0,0,0);
  return Math.max(0, Math.min(Math.floor((now-s)/(864e5)), DAYS.length-1));
}

function load() {
  try { return JSON.parse(localStorage.getItem('ai30-done')||'{}'); }
  catch(e){ return {}; }
}
function save(d){ localStorage.setItem('ai30-done', JSON.stringify(d)); }

function toggle(i){
  const d = load(); d[i] = !d[i]; save(d); render();
}

function completeTodayFromBanner(){
  const i = today(); const d = load(); if(!d[i]){ d[i]=true; save(d); render(); }
}

function typeTag(tp){
  const map = {yt:'rt-yt',course:'rt-course',cert:'rt-cert',read:'rt-read'};
  return map[tp]||'rt-read';
}
function typeLabel(tp){
  const map = {yt:'YT',course:'COURSE',cert:'CERT',read:'READ'};
  return map[tp]||tp.toUpperCase();
}

function render(){
  const todayIdx = today();
  const done = load();
  const completedCount = Object.values(done).filter(Boolean).length;
  const pct = Math.round((completedCount/DAYS.length)*100);

  document.getElementById('stat-done').textContent = completedCount;
  document.getElementById('stat-today').textContent = Math.min(todayIdx+1, DAYS.length);
  document.getElementById('stat-pct').textContent = pct+'%';
  document.getElementById('progress-fill').style.width = pct+'%';

  // Today banner
  const td = DAYS[todayIdx];
  if(td){
    document.getElementById('today-title').textContent = 'Μέρα '+(todayIdx+1)+': '+td.t;
    document.getElementById('today-desc').textContent = td.d;
    const tb = document.getElementById('today-btn');
    if(done[todayIdx]){ tb.textContent = '✓ Ολοκληρώθηκε!'; tb.className='complete-btn done'; }
    else { tb.textContent = '✓ Ολοκλήρωσα το μάθημα'; tb.className='complete-btn'; }
  }

  // Days
  const root = document.getElementById('days-root');
  root.innerHTML = '';
  let curWeek = null, weekEl = null, gridEl = null;

  DAYS.forEach(function(d, i){
    if(d.week !== curWeek){
      curWeek = d.week;
      weekEl = document.createElement('div');
      weekEl.className = 'week-block';
      if(d.wt){
        const wh = document.createElement('div');
        wh.className = 'week-header';
        wh.innerHTML = '<h2>'+d.wt+'</h2>'+(d.ws?'<p>'+d.ws+'</p>':'');
        weekEl.appendChild(wh);
      }
      gridEl = document.createElement('div');
      gridEl.className = 'days-grid';
      weekEl.appendChild(gridEl);
      root.appendChild(weekEl);
    }

    const isToday = i===todayIdx;
    const isDone = !!done[i];

    const card = document.createElement('div');
    card.className = 'day-card'+(isToday?' is-today':'')+(isDone?' is-done':'');

    const resHtml = (d.r||[]).map(function(r){
      return '<a class="res-link" href="'+r.u+'" target="_blank">'
        +'<span class="res-flag">'+r.f+'</span>'
        +'<span class="res-type '+typeTag(r.tp)+'">'+typeLabel(r.tp)+'</span>'
        +'<span class="res-title">'+r.n+'</span>'
        +'<span class="res-free">FREE</span>'
        +'</a>';
    }).join('');

    const btnLabel = isDone ? '✓ Ολοκληρώθηκε!' : '✓ Ολοκλήρωσα το μάθημα';
    const btnClass = isDone ? 'day-complete-btn done' : 'day-complete-btn';

    card.innerHTML = '<div class="day-meta"><span class="day-num-label">'
      +(isToday?'▶ ':'')+'Μέρα '+(i+1)+'</span></div>'
      +'<div class="day-title">'+d.t+'</div>'
      +'<div class="day-desc">'+d.d+'</div>'
      +'<div class="res-list">'+resHtml+'</div>'
      +'<button class="'+btnClass+'"'+(isDone?' disabled':'')+' onclick="toggle('+i+')">'+btnLabel+'</button>';

    gridEl.appendChild(card);
  });
}

render();
</script>
