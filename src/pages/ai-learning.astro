---
import Base from "../layouts/Base.astro";
---

<Base
  title="AI Expert 30-Day Plan — David"
  description="30-ήμερο πρόγραμμα εκπαίδευσης AI — resources σε Ρωσικά, Ελληνικά, Αγγλικά."
>
<main class="lp">

  <!-- Header -->
  <section class="lp-hero">
    <div class="lp-container">
      <p class="eyebrow">AI Expert Plan · David × Silvy · 25 Ιουνίου 2026</p>
      <h1>30-Ήμερο Πρόγραμμα AI</h1>
      <p class="sub">🇷🇺 Ρωσικά · 🇬🇷 Ελληνικά · 🇬🇧 Αγγλικά</p>

      <div class="top-stats">
        <div class="ts-item">
          <span class="ts-num" id="s-done">0</span>
          <span class="ts-lbl">Ολοκληρωμένες</span>
        </div>
        <div class="ts-sep"></div>
        <div class="ts-item">
          <span class="ts-num" id="s-day">1</span>
          <span class="ts-lbl">Σημερινή ημέρα</span>
        </div>
        <div class="ts-sep"></div>
        <div class="ts-item">
          <span class="ts-num" id="s-pct">0%</span>
          <span class="ts-lbl">Συνολική πρόοδος</span>
        </div>
      </div>

      <div class="overall-bar-wrap">
        <div class="overall-bar" id="overall-bar"></div>
      </div>
    </div>
  </section>

  <!-- Today banner -->
  <div class="lp-container">
    <div class="today-strip" id="today-strip">
      <div>
        <span class="today-tag">▶ ΣΗΜΕΡΑ</span>
        <strong id="td-title"></strong>
        <span id="td-desc"></span>
      </div>
      <button class="td-btn" id="td-btn" onclick="completeToday()">✓ Ολοκλήρωσα</button>
    </div>
  </div>

  <!-- Certs -->
  <div class="lp-container">
    <div class="cert-strip">
      <span class="cert-lbl">🎓 Στόχοι:</span>
      <a href="https://grow.google/ai" target="_blank" class="cpill">Google AI Essentials (free)</a>
      <a href="https://learn.microsoft.com/en-us/credentials/certifications/ai-business-professional/" target="_blank" class="cpill">Microsoft AI Business Pro (~€100)</a>
    </div>
  </div>

  <!-- Weeks accordion -->
  <div class="lp-container" id="root"></div>

</main>

<style is:global>
  :root{--g:#d4af57;--g2:#f0cc7a;--n:#0a0f1e;--n2:#111827;--n3:#1c2737;--ink:#e8e8f0;--ink2:#9ca3af;--ink3:#6b7280;--green:#10b981}
  *{box-sizing:border-box;margin:0;padding:0}
  body{background:var(--n);color:var(--ink);font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}
  .lp{max-width:100%;overflow-x:hidden}
  .lp-container{max-width:860px;margin:0 auto;padding:0 1.5rem}

  /* Hero */
  .lp-hero{padding:4.5rem 0 2.5rem;text-align:center;border-bottom:1px solid rgba(212,175,87,.12);background:radial-gradient(ellipse at 50% 0%,rgba(212,175,87,.07) 0%,transparent 70%)}
  .eyebrow{font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--g);margin-bottom:.9rem}
  .lp-hero h1{font-family:var(--font-display,Georgia,serif);font-size:clamp(1.8rem,5vw,2.8rem);font-weight:700;color:var(--ink);margin-bottom:.5rem}
  .sub{color:var(--ink2);font-size:.95rem;margin-bottom:2rem}

  .top-stats{display:inline-flex;background:rgba(255,255,255,.03);border:1px solid rgba(212,175,87,.15);border-radius:12px;overflow:hidden;margin-bottom:1.25rem}
  .ts-item{padding:.9rem 1.75rem;text-align:center}
  .ts-sep{width:1px;background:rgba(255,255,255,.07)}
  .ts-num{display:block;font-family:var(--font-display,Georgia,serif);font-size:1.7rem;font-weight:700;color:var(--g);line-height:1;margin-bottom:.2rem}
  .ts-lbl{font-size:.65rem;color:var(--ink3);text-transform:uppercase;letter-spacing:.06em}

  .overall-bar-wrap{background:rgba(255,255,255,.08);border-radius:99px;height:6px;max-width:360px;margin:0 auto;overflow:hidden}
  .overall-bar{height:100%;border-radius:99px;background:linear-gradient(90deg,var(--g),var(--g2));transition:width .5s ease;width:0%}

  /* Today strip */
  .today-strip{margin:1.5rem 0 1rem;background:linear-gradient(135deg,rgba(212,175,87,.1),rgba(212,175,87,.03));border:1px solid rgba(212,175,87,.35);border-radius:12px;padding:1.25rem 1.5rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap}
  .today-strip>div{flex:1;min-width:180px;display:flex;flex-direction:column;gap:.25rem}
  .today-tag{font-size:.65rem;font-weight:700;letter-spacing:.1em;color:var(--g);text-transform:uppercase}
  .today-strip strong{font-size:.95rem;color:var(--ink)}
  .today-strip span{font-size:.8rem;color:var(--ink2);line-height:1.5}
  .td-btn{background:var(--g);color:var(--n);font-weight:700;font-size:.83rem;padding:.7rem 1.3rem;border-radius:7px;border:none;cursor:pointer;white-space:nowrap;transition:background .2s,transform .15s;flex-shrink:0}
  .td-btn:hover{background:var(--g2);transform:translateY(-1px)}
  .td-btn.done{background:var(--green);color:#fff;cursor:default;transform:none}

  /* Certs */
  .cert-strip{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;margin-bottom:2rem;padding:.8rem 1rem;background:rgba(212,175,87,.03);border:1px solid rgba(212,175,87,.1);border-radius:9px}
  .cert-lbl{font-size:.75rem;color:var(--ink2);white-space:nowrap}
  .cpill{font-size:.72rem;color:var(--g);border:1px solid rgba(212,175,87,.28);border-radius:99px;padding:.25rem .75rem;text-decoration:none;white-space:nowrap;transition:background .15s}
  .cpill:hover{background:rgba(212,175,87,.1)}

  /* Week block */
  .week-block{margin-bottom:1.25rem;border:1px solid rgba(255,255,255,.07);border-radius:14px;overflow:hidden}

  .week-head{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.25rem;cursor:pointer;background:rgba(255,255,255,.02);transition:background .15s;gap:1rem;user-select:none}
  .week-head:hover{background:rgba(255,255,255,.04)}
  .wh-left{display:flex;align-items:center;gap:.85rem;flex:1;min-width:0}
  .wh-title{font-size:.85rem;font-weight:700;color:var(--g);text-transform:uppercase;letter-spacing:.07em;white-space:nowrap}
  .wh-sub{font-size:.78rem;color:var(--ink3);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

  .wh-right{display:flex;align-items:center;gap:.85rem;flex-shrink:0}
  .week-progress-wrap{width:100px;background:rgba(255,255,255,.08);border-radius:99px;height:5px;overflow:hidden}
  .week-progress-fill{height:100%;border-radius:99px;background:var(--g);transition:width .4s ease}
  .wh-pct{font-size:.7rem;color:var(--ink3);min-width:28px;text-align:right}
  .wh-arrow{font-size:.7rem;color:var(--ink3);transition:transform .25s}
  .week-block.open .wh-arrow{transform:rotate(180deg)}

  /* Days list */
  .days-list{display:none;flex-direction:column;border-top:1px solid rgba(255,255,255,.05)}
  .week-block.open .days-list{display:flex}

  /* Day row */
  .day-row{border-bottom:1px solid rgba(255,255,255,.04)}
  .day-row:last-child{border-bottom:none}

  .day-head{display:flex;align-items:center;gap:.75rem;padding:.85rem 1.25rem;cursor:pointer;transition:background .15s;user-select:none}
  .day-head:hover{background:rgba(255,255,255,.02)}
  .day-row.open .day-head{background:rgba(212,175,87,.04)}

  .day-check{width:22px;height:22px;border-radius:50%;border:2px solid rgba(255,255,255,.15);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:.65rem;transition:all .2s}
  .day-check.done{background:var(--green);border-color:var(--green);color:#fff}
  .day-check.today{border-color:var(--g)}

  .day-num{font-size:.68rem;font-weight:700;color:var(--ink3);letter-spacing:.05em;text-transform:uppercase;min-width:48px;flex-shrink:0}
  .day-row.is-today .day-num{color:var(--g)}
  .day-title-row{font-size:.88rem;color:var(--ink);flex:1}
  .day-row.is-today .day-title-row{color:var(--g2)}
  .day-arrow{font-size:.65rem;color:var(--ink3);transition:transform .22s;flex-shrink:0}
  .day-row.open .day-arrow{transform:rotate(180deg)}

  /* Day body */
  .day-body{display:none;padding:.1rem 1.25rem 1.25rem 1.25rem;padding-left:calc(1.25rem + 22px + .75rem + 48px + .75rem)}
  .day-row.open .day-body{display:block}

  .day-desc-text{font-size:.82rem;color:var(--ink2);line-height:1.6;margin-bottom:.85rem}
  .res-list{display:flex;flex-direction:column;gap:.3rem;margin-bottom:.9rem}
  .res-a{display:flex;align-items:center;gap:.4rem;padding:.38rem .6rem;border-radius:6px;background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.05);text-decoration:none;transition:all .12s}
  .res-a:hover{background:rgba(212,175,87,.07);border-color:rgba(212,175,87,.2)}
  .rflag{font-size:.82rem;flex-shrink:0}
  .rtype{font-size:.58rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase;padding:.1rem .35rem;border-radius:3px;flex-shrink:0}
  .yt{background:rgba(255,50,50,.15);color:#ff7070}
  .course{background:rgba(60,130,246,.15);color:#7ab4ff}
  .cert{background:rgba(212,175,87,.15);color:var(--g)}
  .read{background:rgba(16,185,129,.15);color:#4ade80}
  .rtitle{font-size:.75rem;color:var(--ink2);line-height:1.3;flex:1}
  .res-a:hover .rtitle{color:var(--ink)}
  .rfree{margin-left:auto;font-size:.58rem;color:#4ade80;font-weight:700;flex-shrink:0}

  .complete-btn{width:100%;padding:.6rem;border-radius:7px;border:1px solid rgba(212,175,87,.3);background:transparent;color:var(--g);font-size:.8rem;font-weight:600;cursor:pointer;transition:all .15s}
  .complete-btn:hover{background:rgba(212,175,87,.08);border-color:rgba(212,175,87,.55)}
  .complete-btn.done{background:rgba(16,185,129,.1);border-color:rgba(16,185,129,.3);color:#4ade80;cursor:default}

  @media(max-width:600px){
    .lp-container{padding:0 1rem}
    .day-body{padding-left:1rem}
    .ts-item{padding:.75rem 1.25rem}
    .wh-sub{display:none}
  }
</style>

