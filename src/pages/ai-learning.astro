const FLAT=[]; WEEKS.forEach(function(w){w.days.forEach(function(d){FLAT.push(d);});});

function todayIdx(){
  var n=new Date();n.setHours(0,0,0,0);
  var s=new Date(START);s.setHours(0,0,0,0);
  return Math.max(0,Math.min(Math.floor((n-s)/864e5),FLAT.length-1));
}
function ld(){try{return JSON.parse(localStorage.getItem('ai30v3')||'{}');}catch(e){return{};}}
function sv(d){localStorage.setItem('ai30v3',JSON.stringify(d));}

function toggleDay(gi){var d=ld();d[gi]=!d[gi];sv(d);render();}
function completeToday(){var i=todayIdx();var d=ld();if(!d[i]){d[i]=true;sv(d);render();}}

function tc(tp){return({yt:'yt',course:'course',cert:'cert',read:'read'})[tp]||'read';}
function tl(tp){return({yt:'YT',course:'COURSE',cert:'CERT',read:'READ'})[tp]||(tp||'').toUpperCase();}

function render(){
  var ti=todayIdx(), done=ld(), total=FLAT.length;
  var cnt=Object.values(done).filter(Boolean).length;
  var pct=Math.round((cnt/total)*100);

  document.getElementById('s-done').textContent=cnt;
  document.getElementById('s-day').textContent=Math.min(ti+1,total);
  document.getElementById('s-pct').textContent=pct+'%';
  document.getElementById('overall-bar').style.width=pct+'%';

  var td=FLAT[ti];
  document.getElementById('td-title').textContent='Μέρα '+(ti+1)+': '+td.t;
  document.getElementById('td-desc').textContent=td.d;
  var tdb=document.getElementById('td-btn');
  if(done[ti]){tdb.textContent='✓ Ολοκληρώθηκε!';tdb.className='alp-today-btn done';}
  else{tdb.textContent='✓ Ολοκλήρωσα';tdb.className='alp-today-btn';}

  // Save open state
  var openW={},openL={};
  document.querySelectorAll('.alp-week').forEach(function(el,i){openW[i]=el.classList.contains('open');});
  document.querySelectorAll('.alp-lesson').forEach(function(el){if(el.dataset.gi!=null)openL[el.dataset.gi]=el.classList.contains('open');});

  var root=document.getElementById('alp-root');
  root.innerHTML='';
  var gi=0;

  WEEKS.forEach(function(w,wi){
    var wDone=w.days.filter(function(d,di){return!!done[gi+di];}).length;
    var wTotal=w.days.length;
    var wPct=Math.round((wDone/wTotal)*100);
    var wOpen=openW[wi]!==undefined?openW[wi]:w.days.some(function(d,di){return(gi+di)===ti;});

    var block=document.createElement('div');
    block.className='alp-week'+(wOpen?' open':'');
    block.innerHTML='<div class="alp-week-head" onclick="this.closest(\'.alp-week\').classList.toggle(\'open\')">'
      +'<div class="alp-week-left"><span class="alp-week-num">'+w.wt+'</span><span class="alp-week-sub">'+w.ws+'</span></div>'
      +'<div class="alp-week-right">'
      +'<div class="alp-week-prog-wrap"><div class="alp-week-prog-fill" style="width:'+wPct+'%"></div></div>'
      +'<span class="alp-week-counter">'+wDone+'/'+wTotal+'</span>'
      +'<span class="alp-week-arrow">▼</span>'
      +'</div></div>'
      +'<div class="alp-lessons"></div>';

    var lessons=block.querySelector('.alp-lessons');

    w.days.forEach(function(d,di){
      var idx=gi+di;
      var isToday=idx===ti, isDone=!!done[idx];
      var lOpen=openL[idx]!==undefined?openL[idx]:isToday;

      var row=document.createElement('div');
      row.className='alp-lesson'+(isToday?' is-today':'')+(isDone?' done-lesson':'')+(lOpen?' open':'');
      row.dataset.gi=idx;

      var chk='<div class="alp-check'+(isDone?' done':'')+(isToday&&!isDone?' today':'')+'">'+(isDone?'✓':'')+'</div>';

      var resHtml=(d.r||[]).map(function(r){
        return '<a class="alp-res-a" href="'+r.u+'" target="_blank">'
          +'<span class="alp-rflag">'+r.f+'</span>'
          +'<span class="alp-rtype '+tc(r.tp)+'">'+tl(r.tp)+'</span>'
          +'<span class="alp-rtitle">'+r.n+'</span>'
          +'<span class="alp-rfree">FREE</span>'
          +'</a>';
      }).join('');

      var btnLabel=isDone?'✓ Ολοκληρώθηκε!':'Επισήμανση ως ολοκληρωμένο';
      var btnClass='alp-complete-btn '+(isDone?'done':'pending');

      row.innerHTML='<div class="alp-lesson-head" onclick="this.closest(\'.alp-lesson\').classList.toggle(\'open\')">'
        +chk
        +'<span class="alp-lesson-num">'+(isToday?'▶ ':'')+'Μέρα '+(idx+1)+'</span>'
        +'<span class="alp-lesson-title">'+d.t+'</span>'
        +'<span class="alp-lesson-arrow">▼</span>'
        +'</div>'
        +'<div class="alp-lesson-body">'
        +'<div class="alp-lesson-inner">'
        +'<p class="alp-lesson-desc">'+d.d+'</p>'
        +'<p class="alp-res-label">Υλικό μαθήματος</p>'
        +'<div class="alp-res-list">'+resHtml+'</div>'
        +'<button class="'+btnClass+'"'+(isDone?' disabled':'')+' onclick="toggleDay('+idx+')">'+btnLabel+'</button>'
        +'</div></div>';

      lessons.appendChild(row);
    });

    root.appendChild(block);
    gi+=w.days.length;
  });
}

render();
</script>

