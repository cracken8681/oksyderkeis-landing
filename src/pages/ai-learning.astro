---
import Base from "../layouts/Base.astro";
---

<Base
  title="AI Expert 30-Day Plan — David"
  description="30-ήμερο πρόγραμμα εκπαίδευσης AI."
>

<style is:global>
  .alp { max-width:100%; overflow-x:hidden; background:var(--color-navy-950,#0a0f1e); min-height:100vh; }
  .alp-wrap { max-width:780px; margin:0 auto; padding:0 1.25rem 4rem; }

  /* Hero */
  .alp-hero { padding:3.5rem 0 2rem; border-bottom:1px solid rgba(212,175,87,.14); margin-bottom:1.75rem; }
  .alp-eyebrow { font-size:.7rem; letter-spacing:.14em; text-transform:uppercase; color:#d4af57; margin-bottom:.75rem; }
  .alp-hero h1 { font-family:var(--font-display,Georgia,serif); font-size:clamp(1.6rem,4vw,2.4rem); font-weight:700; color:#e8e8f0; margin-bottom:.4rem; }
  .alp-hero p { font-size:.88rem; color:#9ca3af; }

  /* Top stats */
  .alp-stats { display:flex; gap:0; background:rgba(255,255,255,.03); border:1px solid rgba(212,175,87,.14); border-radius:10px; overflow:hidden; margin:1.25rem 0; display:inline-flex; }
  .alp-stat { padding:.75rem 1.5rem; text-align:center; }
  .alp-stat-sep { width:1px; background:rgba(255,255,255,.07); }
  .alp-stat-num { display:block; font-family:var(--font-display,Georgia,serif); font-size:1.5rem; font-weight:700; color:#d4af57; line-height:1; margin-bottom:.2rem; }
  .alp-stat-lbl { font-size:.62rem; color:#6b7280; text-transform:uppercase; letter-spacing:.06em; }

  .alp-bar-wrap { background:rgba(255,255,255,.08); border-radius:99px; height:5px; margin-bottom:1.5rem; overflow:hidden; }
  .alp-bar-fill { height:100%; border-radius:99px; background:linear-gradient(90deg,#d4af57,#f0cc7a); transition:width .5s ease; width:0; }

  /* Today strip */
  .alp-today { background:rgba(212,175,87,.08); border:1px solid rgba(212,175,87,.3); border-radius:10px; padding:1rem 1.25rem; margin-bottom:1.5rem; display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap; }
  .alp-today-left { flex:1; min-width:160px; }
  .alp-today-tag { font-size:.62rem; font-weight:700; letter-spacing:.1em; color:#d4af57; text-transform:uppercase; display:block; margin-bottom:.3rem; }
  .alp-today-title { font-size:.92rem; font-weight:700; color:#e8e8f0; display:block; margin-bottom:.15rem; }
  .alp-today-desc { font-size:.78rem; color:#9ca3af; line-height:1.45; }
  .alp-today-btn { background:#d4af57; color:#0a0f1e; font-weight:700; font-size:.82rem; padding:.65rem 1.2rem; border-radius:7px; border:none; cursor:pointer; white-space:nowrap; transition:background .15s; flex-shrink:0; }
  .alp-today-btn:hover { background:#f0cc7a; }
  .alp-today-btn.done { background:#10b981; color:#fff; cursor:default; }

  /* Week section */
  .alp-week { margin-bottom:1rem; border:1px solid rgba(255,255,255,.07); border-radius:12px; overflow:hidden; }

  .alp-week-head {
    display:flex; align-items:center; justify-content:space-between;
    padding:.9rem 1.25rem; cursor:pointer; user-select:none;
    background:rgba(255,255,255,.02); transition:background .15s; gap:.75rem;
  }
  .alp-week-head:hover { background:rgba(255,255,255,.04); }
  .alp-week-left { display:flex; align-items:center; gap:.75rem; flex:1; min-width:0; }
  .alp-week-num { font-size:.7rem; font-weight:700; color:#d4af57; text-transform:uppercase; letter-spacing:.08em; white-space:nowrap; }
  .alp-week-sub { font-size:.78rem; color:#6b7280; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .alp-week-right { display:flex; align-items:center; gap:.75rem; flex-shrink:0; }
  .alp-week-prog-wrap { width:80px; background:rgba(255,255,255,.08); border-radius:99px; height:4px; overflow:hidden; }
  .alp-week-prog-fill { height:100%; border-radius:99px; background:#d4af57; transition:width .35s; }
  .alp-week-counter { font-size:.7rem; color:#6b7280; white-space:nowrap; }
  .alp-week-arrow { font-size:.65rem; color:#6b7280; transition:transform .22s; flex-shrink:0; }
  .alp-week.open .alp-week-arrow { transform:rotate(180deg); }

  /* Lessons list */
  .alp-lessons { display:none; border-top:1px solid rgba(255,255,255,.05); }
  .alp-week.open .alp-lessons { display:block; }

  /* Lesson row */
  .alp-lesson { border-bottom:1px solid rgba(255,255,255,.04); }
  .alp-lesson:last-child { border-bottom:none; }

  .alp-lesson-head {
    display:flex; align-items:center; gap:.75rem;
    padding:.8rem 1.25rem; cursor:pointer; user-select:none;
    transition:background .12s;
  }
  .alp-lesson-head:hover { background:rgba(255,255,255,.02); }
  .alp-lesson.open .alp-lesson-head { background:rgba(212,175,87,.04); }

  /* Checkmark circle */
  .alp-check {
    width:20px; height:20px; border-radius:50%; flex-shrink:0;
    border:2px solid rgba(255,255,255,.18);
    display:flex; align-items:center; justify-content:center;
    font-size:.6rem; font-weight:700; color:#fff;
    transition:all .2s;
  }
  .alp-check.done { background:#10b981; border-color:#10b981; }
  .alp-check.today { border-color:#d4af57; }

  .alp-lesson-num { font-size:.68rem; color:#6b7280; font-weight:600; min-width:44px; flex-shrink:0; }
  .alp-lesson.is-today .alp-lesson-num { color:#d4af57; }
  .alp-lesson-title { flex:1; font-size:.87rem; color:#d1d5db; line-height:1.35; }
  .alp-lesson.is-today .alp-lesson-title { color:#f0cc7a; font-weight:600; }
  .alp-lesson.done-lesson .alp-lesson-title { color:#6b7280; }
  .alp-lesson-arrow { font-size:.6rem; color:#6b7280; transition:transform .2s; flex-shrink:0; }
  .alp-lesson.open .alp-lesson-arrow { transform:rotate(180deg); }

  /* Lesson body — Filmareto-style */
  .alp-lesson-body { display:none; }
  .alp-lesson.open .alp-lesson-body { display:block; }

  .alp-lesson-inner { padding:0 1.25rem 1.5rem 1.25rem; padding-left:calc(1.25rem + 20px + .75rem + 44px + .75rem); }

  .alp-lesson-desc { font-size:.84rem; color:#9ca3af; line-height:1.65; margin-bottom:1.1rem; padding-top:.5rem; }

  .alp-res-label { font-size:.65rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:#6b7280; margin-bottom:.5rem; }

  .alp-res-list { display:flex; flex-direction:column; gap:.3rem; margin-bottom:1.5rem; }

  .alp-res-a {
    display:flex; align-items:center; gap:.45rem;
    padding:.4rem .65rem; border-radius:7px;
    background:rgba(255,255,255,.025); border:1px solid rgba(255,255,255,.06);
    text-decoration:none; transition:all .12s;
  }
  .alp-res-a:hover { background:rgba(212,175,87,.07); border-color:rgba(212,175,87,.22); }
  .alp-rflag { font-size:.82rem; flex-shrink:0; }
  .alp-rtype { font-size:.58rem; font-weight:700; letter-spacing:.04em; text-transform:uppercase; padding:.1rem .35rem; border-radius:3px; flex-shrink:0; }
  .alp-rtype.yt { background:rgba(255,50,50,.15); color:#ff7070; }
  .alp-rtype.course { background:rgba(60,130,246,.15); color:#7ab4ff; }
  .alp-rtype.cert { background:rgba(212,175,87,.15); color:#d4af57; }
  .alp-rtype.read { background:rgba(16,185,129,.15); color:#4ade80; }
  .alp-rtitle { font-size:.76rem; color:#9ca3af; line-height:1.3; flex:1; }
  .alp-res-a:hover .alp-rtitle { color:#e8e8f0; }
  .alp-rfree { margin-left:auto; font-size:.58rem; color:#4ade80; font-weight:700; flex-shrink:0; }

  /* Big complete button — like Filmareto */
  .alp-complete-btn {
    display:block; width:100%;
    padding:.9rem 1.5rem;
    border-radius:8px;
    border:none;
    font-size:.9rem; font-weight:700;
    cursor:pointer;
    transition:all .2s;
    text-align:center;
  }
  .alp-complete-btn.pending {
    background:rgba(212,175,87,.12);
    border:2px solid rgba(212,175,87,.4);
    color:#d4af57;
  }
  .alp-complete-btn.pending:hover { background:rgba(212,175,87,.2); border-color:#d4af57; transform:translateY(-1px); }
  .alp-complete-btn.done {
    background:rgba(16,185,129,.12);
    border:2px solid rgba(16,185,129,.35);
    color:#4ade80;
    cursor:default;
  }

  @media(max-width:600px){
    .alp-wrap{ padding:0 .875rem 3rem; }
    .alp-lesson-inner{ padding-left:.875rem; }
    .alp-week-sub{ display:none; }
    .alp-stat{ padding:.65rem 1rem; }
  }
</style>

<main class="alp">
  <div class="alp-wrap">

    <!-- Hero -->
    <div class="alp-hero">
      <p class="alp-eyebrow">AI Expert Plan · David × Silvy · 25 Ιουνίου 2026</p>
      <h1>30-Ήμερο Πρόγραμμα AI</h1>
      <p>🇷🇺 Ρωσικά · 🇬🇷 Ελληνικά · 🇬🇧 Αγγλικά</p>
      <div class="alp-stats">
        <div class="alp-stat"><span class="alp-stat-num" id="s-done">0</span><span class="alp-stat-lbl">Ολοκληρωμένες</span></div>
        <div class="alp-stat-sep"></div>
        <div class="alp-stat"><span class="alp-stat-num" id="s-day">1</span><span class="alp-stat-lbl">Σημερινή μέρα</span></div>
        <div class="alp-stat-sep"></div>
        <div class="alp-stat"><span class="alp-stat-num" id="s-pct">0%</span><span class="alp-stat-lbl">Πρόοδος</span></div>
      </div>
      <div class="alp-bar-wrap"><div class="alp-bar-fill" id="overall-bar"></div></div>
    </div>

    <!-- Today -->
    <div class="alp-today">
      <div class="alp-today-left">
        <span class="alp-today-tag">▶ ΣΗΜΕΡΑ</span>
        <span class="alp-today-title" id="td-title"></span>
        <span class="alp-today-desc" id="td-desc"></span>
      </div>
      <button class="alp-today-btn" id="td-btn" onclick="completeToday()">✓ Ολοκλήρωσα</button>
    </div>

    <!-- Weeks -->
    <div id="alp-root"></div>

  </div>
</main>

